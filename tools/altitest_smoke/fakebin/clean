#!/usr/bin/env bash
set -euo pipefail
if [[ "${FAKE_CLEAN_FAIL:-0}" == "1" ]]; then
  echo "simulated clean failure" >&2
  exit 1
fi
state_dir="${ALTI_FAKE_STATE_DIR:-/tmp/altitest_fake_server_${USER}}"
pid_file="$state_dir/server.pid"
if [[ -f "$pid_file" ]]; then
  pid="$(cat "$pid_file")"
  if kill -0 "$pid" 2>/dev/null; then
    kill "$pid" >/dev/null 2>&1 || true
  fi
  rm -f "$pid_file"
fi
exit 0
