#!/usr/bin/env bash
set -euo pipefail
if [[ "${1:-}" != "-f" || -z "${2:-}" ]]; then
  echo "usage: is -f <sqlfile>" >&2
  exit 2
fi
sql_file="$2"
if [[ ! -f "$sql_file" ]]; then
  echo "sql not found: $sql_file" >&2
  exit 2
fi
content="$(cat "$sql_file")"
state_root="${TMPDIR:-/tmp}/altitest_smoke_state"
mkdir -p "$state_root"

while IFS= read -r line; do
  if [[ "$line" =~ ^--CASE:STATE[[:space:]]+SET[[:space:]]+([A-Za-z0-9_.-]+)$ ]]; then
    : > "$state_root/${BASH_REMATCH[1]}"
  fi
done <<<"$content"

missing_state=0
while IFS= read -r line; do
  if [[ "$line" =~ ^--CASE:STATE[[:space:]]+REQUIRE[[:space:]]+([A-Za-z0-9_.-]+)$ ]]; then
    if [[ ! -f "$state_root/${BASH_REMATCH[1]}" ]]; then
      missing_state=1
      break
    fi
  fi
done <<<"$content"

env_mismatch=0
while IFS= read -r line; do
  if [[ "$line" =~ ^--CASE:ENV[[:space:]]+REQUIRE[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
    key="${BASH_REMATCH[1]}"
    expected="${BASH_REMATCH[2]}"
    actual="${!key-}"
    if [[ "$actual" != "$expected" ]]; then
      env_mismatch=1
      break
    fi
  elif [[ "$line" =~ ^--CASE:ENV[[:space:]]+UNSET[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)$ ]]; then
    key="${BASH_REMATCH[1]}"
    if [[ -n "${!key-}" ]]; then
      env_mismatch=1
      break
    fi
  fi
done <<<"$content"

if grep -q -- "--CASE:ERROR" <<<"$content"; then
  echo "simulated execution error" >&2
  exit 1
fi

if [[ "$env_mismatch" -eq 1 ]]; then
  echo "simulated env mismatch" >&2
  exit 1
fi

if grep -q -- "--CASE:FATAL_DISCONNECT" <<<"$content"; then
  echo "ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = ${ALTIBASE_PORT_NO:-20300}"
  echo "[ERR-50032 : Client unable to establish connection. (Failed to invoke the connect() system function, errno=111)]"
  exit 1
fi

if grep -q -- "--CASE:ORDER" <<<"$content"; then
  cat <<'OUT'
ID VAL
2 B
1 A
2 rows selected.
OUT
  exit 0
fi

if grep -q -- "--CASE:FAIL" <<<"$content"; then
  cat <<'OUT'
ID VAL
1 A
2 X
2 rows selected.
OUT
  exit 0
fi

if [[ "$missing_state" -eq 1 ]]; then
  cat <<'OUT'
ID VAL
1 A
2 X
2 rows selected.
OUT
  exit 0
fi

cat <<'OUT'
ID VAL
1 A
2 B
2 rows selected.
OUT
exit 0
