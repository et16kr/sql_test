ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify LEFT OUTER sort-join hit/no-hit row preservation.
iSQL> -- Checks: Matched rows and left-side unmatched rows are both correct.
iSQL> -- Disk sort temp coverage 12: LEFT OUTER JOIN with sort join (hit/nohit path)
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV12_A
(
    ID     INTEGER,
    K1     INTEGER,
    PAD1   VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> CREATE TABLE DST_COV12_B
(
    ID     INTEGER,
    K1     INTEGER,
    PAD1   VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV12_A
SELECT LEVEL,
       LEVEL,
       RPAD('LA' || TO_CHAR(LEVEL), 3200, 'L')
  FROM DUAL
CONNECT BY LEVEL <= 1200;
1200 rows inserted.
iSQL> INSERT INTO DST_COV12_B
SELECT LEVEL,
       LEVEL * 2,
       RPAD('LB' || TO_CHAR(LEVEL), 3200, 'R')
  FROM DUAL
CONNECT BY LEVEL <= 700;
700 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK USE_SORT(B, A) NO_USE_HASH(B) */
       SUM(CASE WHEN B.K1 IS NULL THEN 1 ELSE 0 END) AS LEFT_ONLY_CNT,
       COUNT(*) AS TOTAL_CNT
  FROM DST_COV12_A A LEFT OUTER JOIN DST_COV12_B B
    ON A.K1 = B.K1;
LEFT_ONLY_CNT TOTAL_CNT            
--------------------------------------
600         1200                 
1 row selected.
iSQL> DROP TABLE DST_COV12_A;
Drop success.
iSQL> DROP TABLE DST_COV12_B;
Drop success.
