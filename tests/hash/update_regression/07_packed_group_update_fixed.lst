ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify packed-row update on fixed columns and GROUP_HASH re-read correctness.
iSQL> -- Checks: Allowed updates are reflected and grouped aggregates stay correct.
iSQL> -- Disk hash temp packed-row coverage H07: packed update path with fixed aggregate columns
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DHASH_COV07
(
    ID       INTEGER,
    K1       VARCHAR(128),
    N1       NUMERIC(12),
    PAD1     VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DHASH_COV07
SELECT LEVEL,
       'G' || LPAD(TO_CHAR(MOD(LEVEL, 311)), 4, '0'),
       MOD(LEVEL * 7, 1000),
       RPAD('UP' || TO_CHAR(LEVEL), 3200, 'U')
  FROM DUAL
CONNECT BY LEVEL <= 5000;
5000 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK GROUP_HASH */
       K1,
       COUNT(*) AS CNT_V,
       SUM(N1) AS SUM_V,
       MIN(N1) AS MIN_V,
       MAX(N1) AS MAX_V
  FROM DHASH_COV07
 GROUP BY K1
 ORDER BY K1
 LIMIT 40;
