40 rows selected.
iSQL> SELECT CASE WHEN H.SUM_N1 = B.SUM_N1 THEN 1 ELSE 0 END AS PASS_SUM
  FROM (
        SELECT SUM(SUM_V) AS SUM_N1
          FROM (
                SELECT /*+ TEMP_TBS_DISK GROUP_HASH */
                       K1,
                       SUM(N1) AS SUM_V
                  FROM DHASH_COV07
                 GROUP BY K1
               ) G
       ) H,
       (
        SELECT SUM(N1) AS SUM_N1
          FROM DHASH_COV07
       ) B;
PASS_SUM    
--------------
1           
1 row selected.
iSQL> SELECT CASE WHEN SUM(CNT_V) = 5000 THEN 1 ELSE 0 END AS PASS_CNT
  FROM (
        SELECT /*+ TEMP_TBS_DISK GROUP_HASH */
               K1,
               COUNT(*) AS CNT_V
          FROM DHASH_COV07
         GROUP BY K1
       ) G;
PASS_CNT    
--------------
1           
1 row selected.
iSQL> DROP TABLE DHASH_COV07;
Drop success.
