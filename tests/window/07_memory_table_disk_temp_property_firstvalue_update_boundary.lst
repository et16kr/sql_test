31 rows selected.
iSQL> SELECT CASE
           WHEN (
                SELECT COUNT(*)
                  FROM (
                        SELECT GRP_ID,
                               DENSE_RANK() OVER (
                                   PARTITION BY GRP_ID
                                   ORDER BY V_SORT DESC, ID
                               ) AS DRANK
                          FROM DWIN_COV07_MEM_UPD
                       ) W
                 WHERE DRANK = 1
                ) = 31
           THEN 1 ELSE 0
       END AS PASS_TOP1_CNT
  FROM DUAL;
PASS_TOP1_CNT 
----------------
1           
1 row selected.
iSQL> SELECT CASE
           WHEN (
                SELECT COUNT(*)
                  FROM (
                        SELECT DISTINCT
                               LENGTH(
                                   FIRST_VALUE(V_PAYLOAD) OVER (
                                       PARTITION BY GRP_ID
                                       ORDER BY V_SORT DESC, ID
                                   )
                               ) AS FV_LEN
                          FROM DWIN_COV07_MEM_UPD
                       ) X
                 WHERE FV_LEN IN (14, 15, 3200)
                ) = 3
           THEN 1 ELSE 0
       END AS PASS_FV_LEN_CLASSES
  FROM DUAL;
PASS_FV_LEN_CLASSES 
----------------------
1           
1 row selected.
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 0;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '0' THEN 1 ELSE 0
       END AS PASS_PROP_RESET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_RESET 
------------------
1           
1 row selected.
iSQL> DROP TABLE DWIN_COV07_MEM_UPD;
Drop success.
