ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Validate window sort on memory table with disk-temp default property.
iSQL> -- Checks:
iSQL> --   1) table is created without TABLESPACE clause (memory table path)
iSQL> --   2) __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 2 is applied
iSQL> --   3) window row_number result is correct
iSQL> --   4) property is reset to default (0) at end
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 2;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '2' THEN 1 ELSE 0
       END AS PASS_PROP_SET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_SET 
----------------
1           
1 row selected.
iSQL> CREATE TABLE DWIN_COV06_MEM
(
    ID       INTEGER,
    GRP_ID   INTEGER,
    V1       VARCHAR(512),
    V2       VARCHAR(512)
);
Create success.
iSQL> INSERT INTO DWIN_COV06_MEM
SELECT LEVEL,
       MOD(LEVEL, 37),
       RPAD('A' || TO_CHAR(LEVEL), 300, 'A'),
       RPAD('B' || TO_CHAR(MOD(LEVEL, 100)), 300, 'B')
  FROM DUAL
CONNECT BY LEVEL <= 2400;
2400 rows inserted.
iSQL> SELECT ID, GRP_ID, RN
  FROM (
        SELECT ID,
               GRP_ID,
               ROW_NUMBER() OVER (PARTITION BY GRP_ID ORDER BY V2 DESC, ID) AS RN
          FROM DWIN_COV06_MEM
       ) W
 WHERE RN <= 2
 ORDER BY GRP_ID, RN, ID
 LIMIT 60;
