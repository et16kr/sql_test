60 rows selected.
iSQL> SELECT CASE
           WHEN (
                SELECT COUNT(*)
                  FROM (
                        SELECT ID,
                               GRP_ID,
                               ROW_NUMBER() OVER (
                                   PARTITION BY GRP_ID
                                   ORDER BY V2 DESC, ID
                               ) AS RN
                          FROM DWIN_COV06_MEM
                       ) W
                 WHERE RN = 1
                ) = 37
           THEN 1 ELSE 0
       END AS PASS_WINDOW_TOP1
  FROM DUAL;
PASS_WINDOW_TOP1 
-------------------
1           
1 row selected.
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 0;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '0' THEN 1 ELSE 0
       END AS PASS_PROP_RESET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_RESET 
------------------
1           
1 row selected.
iSQL> DROP TABLE DWIN_COV06_MEM;
Drop success.
