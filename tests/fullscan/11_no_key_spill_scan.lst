ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify NO_MERGE materialization scan path correctness under temp disk execution.
iSQL> -- Checks: Materialized row count and aggregate sum are correct.
iSQL> -- Disk sort temp coverage FS11: no-key materialization spill scan path
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV_FS11
(
    ID       INTEGER,
    GRP_ID   INTEGER,
    PAD1     VARCHAR(3200),
    PAD2     VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV_FS11
SELECT LEVEL,
       MOD(LEVEL, 97),
       RPAD('A' || TO_CHAR(MOD(LEVEL, 500)), 3200, 'A'),
       RPAD('B' || TO_CHAR(MOD(LEVEL, 200)), 3200, 'B')
  FROM DUAL
CONNECT BY LEVEL <= 8000;
8000 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK NO_MERGE(V) */ COUNT(*) AS MAT_CNT
  FROM (
        SELECT ID, GRP_ID, PAD1, PAD2
          FROM DST_COV_FS11
       ) V
 WHERE V.GRP_ID BETWEEN 10 AND 70;
MAT_CNT              
-----------------------
5039                 
1 row selected.
iSQL> SELECT /*+ TEMP_TBS_DISK NO_MERGE(V) */ SUM(V.ID) AS SUM_ID
  FROM (
        SELECT ID, GRP_ID, PAD1
          FROM DST_COV_FS11
       ) V
 WHERE V.GRP_ID IN (3, 7, 11, 13);
SUM_ID               
-----------------------
1323186              
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 8000 THEN 1 ELSE 0 END AS PASS_COUNT
  FROM DST_COV_FS11;
PASS_COUNT  
--------------
1           
1 row selected.
iSQL> DROP TABLE DST_COV_FS11;
Drop success.
