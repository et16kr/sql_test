ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify ORDER BY with NULL values keeps expected null ordering semantics.
iSQL> -- Checks: NULL placement and sorted sequence are correct.
iSQL> -- Disk sort temp coverage FS07: NULLS FIRST/LAST ordered full scan
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV_FS07
(
    ID       INTEGER,
    GRP_ID   INTEGER,
    K1       VARCHAR(64),
    K2       VARCHAR(64),
    PAD1     VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV_FS07
SELECT LEVEL,
       MOD(LEVEL, 41),
       CASE WHEN MOD(LEVEL, 11) = 0 THEN NULL
            ELSE 'K' || LPAD(TO_CHAR(MOD(LEVEL, 300)), 4, '0') END,
       CASE WHEN MOD(LEVEL, 13) = 0 THEN NULL
            ELSE 'S' || LPAD(TO_CHAR(MOD(LEVEL, 500)), 4, '0') END,
       RPAD('N' || TO_CHAR(LEVEL), 3200, 'N')
  FROM DUAL
CONNECT BY LEVEL <= 2100;
2100 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK */ ID, K1, K2
  FROM DST_COV_FS07
 ORDER BY K1 NULLS FIRST, K2 NULLS LAST, ID
 LIMIT 80;
