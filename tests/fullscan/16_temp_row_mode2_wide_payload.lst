iSQL> set timing off;
iSQL>     select
        case when t.temp_pages < (t.data_pages * 2) then 1 else 0 end as is_gt
    from (
        select
            max(case when name = 'DST_COV_FS16_UTMP' then total_page_count end) as temp_pages,
            max(case when name = 'TBS1' then total_page_count end) as data_pages
        from v$tablespaces
    ) t;
