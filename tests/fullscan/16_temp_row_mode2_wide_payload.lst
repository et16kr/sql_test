    , 'admin'
    , SYSDATE
    FROM (SELECT TB1.*
    , ROW_NUMBER() OVER(PARTITION BY BDST_TYPE_SE_CD, MNG_BDST_UNQ_NO ORDER BY
    ROWNUM, HSTRY_END_YM DESC, HSTRY_BGNG_YM DESC) AS SEQNO
    from T0  TB1
    )
    WHERE SEQNO =1;
