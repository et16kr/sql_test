ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify UNION DISTINCT set operation correctness on sort temp path.
iSQL> -- Checks: Duplicate elimination and final ordering are correct.
iSQL> -- Disk sort temp coverage 16: UNION (distinct) + ORDER BY on disk temp
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV16_A
(
    K1     INTEGER,
    K2     VARCHAR(64),
    PAD1   VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> CREATE TABLE DST_COV16_B
(
    K1     INTEGER,
    K2     VARCHAR(64),
    PAD1   VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV16_A
SELECT MOD(LEVEL, 300),
       'A' || TO_CHAR(MOD(LEVEL, 90)),
       RPAD('UA' || TO_CHAR(LEVEL), 3200, 'A')
  FROM DUAL
CONNECT BY LEVEL <= 1200;
1200 rows inserted.
iSQL> INSERT INTO DST_COV16_B
SELECT MOD(LEVEL + 100, 300),
       'B' || TO_CHAR(MOD(LEVEL, 90)),
       RPAD('UB' || TO_CHAR(LEVEL), 3200, 'B')
  FROM DUAL
CONNECT BY LEVEL <= 1200;
1200 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK */ K1, K2
  FROM (
        SELECT K1, K2 FROM DST_COV16_A
        UNION
        SELECT K1, K2 FROM DST_COV16_B
       ) U
 ORDER BY K1, K2
 LIMIT 80;
