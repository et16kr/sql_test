ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify MINUS set operation correctness on sort temp path.
iSQL> -- Checks: Set subtraction result matches expected rows.
iSQL> -- Disk sort temp coverage 17: MINUS + ORDER BY (set operation with disk temp)
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV17_A
(
    K1     INTEGER,
    PAD1   VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> CREATE TABLE DST_COV17_B
(
    K1     INTEGER,
    PAD1   VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV17_A
SELECT LEVEL,
       RPAD('MA' || TO_CHAR(LEVEL), 3200, 'M')
  FROM DUAL
CONNECT BY LEVEL <= 1500;
1500 rows inserted.
iSQL> INSERT INTO DST_COV17_B
SELECT LEVEL * 2,
       RPAD('MB' || TO_CHAR(LEVEL), 3200, 'N')
  FROM DUAL
CONNECT BY LEVEL <= 900;
900 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK */ K1
  FROM (
        SELECT K1 FROM DST_COV17_A
        MINUS
        SELECT K1 FROM DST_COV17_B
       ) M
 ORDER BY K1
 LIMIT 80;
