60 rows selected.
iSQL> SELECT CASE
           WHEN (
                SELECT COUNT(*)
                  FROM (
                        SELECT K1, K2 FROM DSET_COV04_A
                        UNION
                        SELECT K1, K2 FROM DSET_COV04_B
                       ) U
                ) = 600
           THEN 1 ELSE 0
       END AS PASS_UNION_DISTINCT_CNT
  FROM DUAL;
PASS_UNION_DISTINCT_CNT 
--------------------------
0           
1 row selected.
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 0;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '0' THEN 1 ELSE 0
       END AS PASS_PROP_RESET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_RESET 
------------------
1           
1 row selected.
iSQL> DROP TABLE DSET_COV04_A;
Drop success.
iSQL> DROP TABLE DSET_COV04_B;
Drop success.
