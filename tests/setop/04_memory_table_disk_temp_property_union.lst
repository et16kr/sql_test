ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Validate UNION DISTINCT on memory table with disk-temp default property.
iSQL> -- Checks:
iSQL> --   1) tables are created without TABLESPACE clause (memory table path)
iSQL> --   2) __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 2 is applied
iSQL> --   3) union distinct result is correct
iSQL> --   4) property is reset to default (0) at end
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 2;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '2' THEN 1 ELSE 0
       END AS PASS_PROP_SET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_SET 
----------------
1           
1 row selected.
iSQL> CREATE TABLE DSET_COV04_A
(
    K1      INTEGER,
    K2      VARCHAR(64),
    PAD1    VARCHAR(512)
);
Create success.
iSQL> CREATE TABLE DSET_COV04_B
(
    K1      INTEGER,
    K2      VARCHAR(64),
    PAD1    VARCHAR(512)
);
Create success.
iSQL> INSERT INTO DSET_COV04_A
SELECT MOD(LEVEL, 300),
       'A' || TO_CHAR(MOD(LEVEL, 90)),
       RPAD('UA' || TO_CHAR(LEVEL), 300, 'A')
  FROM DUAL
CONNECT BY LEVEL <= 1200;
1200 rows inserted.
iSQL> INSERT INTO DSET_COV04_B
SELECT MOD(LEVEL + 100, 300),
       'B' || TO_CHAR(MOD(LEVEL, 90)),
       RPAD('UB' || TO_CHAR(LEVEL), 300, 'B')
  FROM DUAL
CONNECT BY LEVEL <= 1200;
1200 rows inserted.
iSQL> SELECT K1, K2
  FROM (
        SELECT K1, K2 FROM DSET_COV04_A
        UNION
        SELECT K1, K2 FROM DSET_COV04_B
       ) U
 ORDER BY K1, K2
 LIMIT 60;
