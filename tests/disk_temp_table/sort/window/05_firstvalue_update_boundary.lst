ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Regression test for FIRST_VALUE update-column handling in disk temp window sort.
iSQL> -- Checks: No internal error on mixed payload lengths (14/15/3200) and stable ranking output.
iSQL> -- Disk sort temp coverage WN05: FIRST_VALUE + DENSE_RANK update path with boundary payload lengths
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV_WN05
(
    ID         INTEGER,
    GRP_ID     INTEGER,
    V_PAYLOAD  VARCHAR(3200),
    V_SORT     VARCHAR(3200),
    V_PAD      VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV_WN05
SELECT LEVEL,
       MOD(LEVEL, 29),
       CASE MOD(LEVEL, 3)
            WHEN 0 THEN RPAD('A' || TO_CHAR(LEVEL), 14, 'A')
            WHEN 1 THEN RPAD('B' || TO_CHAR(LEVEL), 15, 'B')
            ELSE RPAD('C' || TO_CHAR(LEVEL), 3200, 'C')
       END,
       RPAD('S' || TO_CHAR(MOD(LEVEL, 240)), 3200, 'S'),
       RPAD('P' || TO_CHAR(MOD(LEVEL, 90)), 3200, 'P')
  FROM DUAL
CONNECT BY LEVEL <= 2200;
2200 rows inserted.
iSQL> SELECT GRP_ID,
       MIN(FV_LEN) AS MIN_FV_LEN,
       MAX(FV_LEN) AS MAX_FV_LEN,
       COUNT(*) AS CNT
  FROM (
        SELECT GRP_ID,
               DENSE_RANK() OVER (PARTITION BY GRP_ID ORDER BY V_SORT DESC, ID) AS DRANK,
               LENGTH(FIRST_VALUE(V_PAYLOAD) OVER (PARTITION BY GRP_ID ORDER BY V_SORT DESC, ID)) AS FV_LEN
          FROM DST_COV_WN05
       ) W
 WHERE DRANK <= 2
 GROUP BY GRP_ID
 ORDER BY GRP_ID;
