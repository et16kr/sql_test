ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Validate disk temp execution on memory table by property.
iSQL> -- Checks:
iSQL> --   1) table is created without TABLESPACE clause (memory table path)
iSQL> --   2) __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 2 is applied
iSQL> --   3) query result is correct
iSQL> --   4) property is reset to default (0) at end
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 2;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '2' THEN 1 ELSE 0
       END AS PASS_PROP_SET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_SET 
----------------
1           
1 row selected.
iSQL> CREATE TABLE DST_COV_FS17_MEM
(
    ID      INTEGER,
    K1      VARCHAR(128),
    PAD1    VARCHAR(512)
);
Create success.
iSQL> INSERT INTO DST_COV_FS17_MEM
SELECT LEVEL,
       'K' || LPAD(TO_CHAR(MOD(LEVEL, 701)), 4, '0'),
       RPAD('M' || TO_CHAR(MOD(LEVEL, 701)), 300, 'M')
  FROM DUAL
CONNECT BY LEVEL <= 4000;
4000 rows inserted.
iSQL> SELECT ID,
       K1
  FROM DST_COV_FS17_MEM
 ORDER BY K1, ID
 LIMIT 20;
