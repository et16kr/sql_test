20 rows selected.
iSQL> SELECT CASE WHEN COUNT(*) = 4000 THEN 1 ELSE 0 END AS PASS_COUNT
  FROM DST_COV_FS17_MEM;
PASS_COUNT  
--------------
1           
1 row selected.
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 0;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '0' THEN 1 ELSE 0
       END AS PASS_PROP_RESET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_RESET 
------------------
1           
1 row selected.
iSQL> DROP TABLE DST_COV_FS17_MEM;
Drop success.
