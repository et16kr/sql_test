ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Validate disk sort/group behavior on memory table with CHAR(>16) + VARCHAR mix.
iSQL> -- Checks:
iSQL> --   1) table is created without TABLESPACE clause (memory table path)
iSQL> --   2) __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 2 is applied
iSQL> --   3) GROUP BY and ORDER BY with mixed fixed/variable columns return deterministic results
iSQL> --   4) property is reset to default (0) at end
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 2;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '2' THEN 1 ELSE 0
       END AS PASS_PROP_SET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_SET 
----------------
1           
1 row selected.
iSQL> CREATE TABLE DST_COV_FS18_MEM_MIX
(
    ID       INTEGER,
    C1       CHAR(32),
    V1       VARCHAR(3200),
    V2       VARCHAR(256)
);
Create success.
iSQL> INSERT INTO DST_COV_FS18_MEM_MIX
SELECT LEVEL,
       RPAD(CHR(65 + MOD(LEVEL, 26)), 32, CHR(65 + MOD(LEVEL, 26))),
       CASE MOD(LEVEL, 3)
            WHEN 0 THEN RPAD('A' || TO_CHAR(LEVEL), 17, 'A')
            WHEN 1 THEN RPAD('B' || TO_CHAR(LEVEL), 33, 'B')
            ELSE RPAD('C' || TO_CHAR(LEVEL), 3000, 'C')
       END,
       RPAD('S' || TO_CHAR(MOD(LEVEL, 151)), 200, 'S')
  FROM DUAL
CONNECT BY LEVEL <= 6000;
6000 rows inserted.
iSQL> SELECT C1,
       CNT_V,
       MIN_L1,
       MAX_L1
  FROM (
        SELECT C1,
               COUNT(*) AS CNT_V,
               MIN(LENGTH(V1)) AS MIN_L1,
               MAX(LENGTH(V1)) AS MAX_L1
          FROM DST_COV_FS18_MEM_MIX
         GROUP BY C1
       ) G
 ORDER BY C1
 LIMIT 12;
