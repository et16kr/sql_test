iSQL> SELECT CASE
           WHEN (
                SELECT COUNT(*)
                  FROM (
                        SELECT C1
                          FROM DST_COV_FS18_MEM_MIX
                         GROUP BY C1
                       ) G
                ) = 26
           THEN 1 ELSE 0
       END AS PASS_GROUP_CNT
  FROM DUAL;
PASS_GROUP_CNT 
-----------------
1           
1 row selected.
iSQL> SELECT CASE
           WHEN (
                SELECT SUM(CNT_V)
                  FROM (
                        SELECT C1, COUNT(*) AS CNT_V
                          FROM DST_COV_FS18_MEM_MIX
                         GROUP BY C1
                       ) G
                ) = 6000
           THEN 1 ELSE 0
       END AS PASS_ROW_SUM
  FROM DUAL;
PASS_ROW_SUM 
---------------
1           
1 row selected.
iSQL> SELECT CASE
           WHEN (
                SELECT COUNT(*)
                  FROM (
                        SELECT C1,
                               MIN(LENGTH(V1)) AS MIN_L1,
                               MAX(LENGTH(V1)) AS MAX_L1
                          FROM DST_COV_FS18_MEM_MIX
                         GROUP BY C1
                       ) G
                 WHERE MIN_L1 = 17
                   AND MAX_L1 = 3000
                ) = 26
           THEN 1 ELSE 0
       END AS PASS_LEN_BOUNDARY
  FROM DUAL;
PASS_LEN_BOUNDARY 
--------------------
1           
1 row selected.
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 0;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '0' THEN 1 ELSE 0
       END AS PASS_PROP_RESET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_RESET 
------------------
1           
1 row selected.
iSQL> DROP TABLE DST_COV_FS18_MEM_MIX;
Drop success.
