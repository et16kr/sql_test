ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify window query correctness after multi-column updates.
iSQL> -- Checks: Updated values are reflected correctly in window-function results.
iSQL> -- Disk sort temp coverage PR02: packed-row window multi-column update scenario
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV_PR02
(
    ID       INTEGER,
    GRP_ID   INTEGER,
    K1       VARCHAR(64),
    V1       VARCHAR(3200),
    V2       VARCHAR(3200),
    V3       VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV_PR02
SELECT LEVEL,
       MOD(LEVEL, 31),
       'K' || LPAD(TO_CHAR(MOD(LEVEL, 700)), 4, '0'),
       RPAD('P' || TO_CHAR(LEVEL), 3200, 'P'),
       RPAD('Q' || TO_CHAR(MOD(LEVEL, 240)), 3200, 'Q'),
       RPAD('R' || TO_CHAR(MOD(LEVEL, 90)), 3200, 'R')
  FROM DUAL
CONNECT BY LEVEL <= 1900;
1900 rows inserted.
iSQL> SELECT ID, GRP_ID, RN, DR, PREV_ID
  FROM (
        SELECT /*+ TEMP_TBS_DISK */
               ID,
               GRP_ID,
               ROW_NUMBER() OVER (PARTITION BY GRP_ID ORDER BY V2 DESC, ID) AS RN,
               DENSE_RANK() OVER (PARTITION BY GRP_ID ORDER BY V2 DESC, ID) AS DR,
               LAG(ID, 1, 0) OVER (PARTITION BY GRP_ID ORDER BY V2 DESC, ID) AS PREV_ID
          FROM DST_COV_PR02
       ) W
 WHERE RN <= 3
 ORDER BY GRP_ID, RN, ID;
