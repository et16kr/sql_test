iSQL> SELECT SUM(CASE WHEN V1 IS NULL THEN 1 ELSE 0 END) AS V1_NULL_CNT,
       SUM(CASE WHEN V2 IS NULL THEN 1 ELSE 0 END) AS V2_NULL_CNT,
       COUNT(*) AS TOTAL_CNT
  FROM DST_COV_PR04;
