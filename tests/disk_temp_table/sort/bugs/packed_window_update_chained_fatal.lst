ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 20101
iSQL> -- Reproducer: FATAL in sort temp packed-row window-update on chained rows
iSQL> --
iSQL> -- Root cause:
iSQL> --   fullscan/14_groupby_repro_mode_compare.sql sets __TEMP_SORT_ROW_PACKING = 1
iSQL> --   at its last statement and never resets it.  Every test that runs after it
iSQL> --   in all.ts inherits that property value.  When packedrow/02_window_multi_update.sql
iSQL> --   runs with packing = 1 it crashes the server.
iSQL> --
iSQL> --   The crash itself is in the Phase-4/5 packed-row UPDATE path of the sort
iSQL> --   temp table.  Window functions (ROW_NUMBER, DENSE_RANK, LAG, …) write back
iSQL> --   their results via smiSortTempTable::update.  When the source row is a
iSQL> --   *chained* packed row (packed value length exceeds one WA page so the row
iSQL> --   spans multiple pages), the update logic enters a code path that is not
iSQL> --   implemented correctly, triggering IDE_ERROR(0) inside checkAndDump which
iSQL> --   crashes the server process.
iSQL> --
iSQL> --   Chained rows are triggered when a table has two or more large VARCHAR
iSQL> --   columns whose combined packed size exceeds a WA page (~8 KB).
iSQL> --   Two VARCHAR(3000) columns filled to capacity produce a packed row of
iSQL> --   roughly 6000+ bytes: this exceeds the internal threshold and forces the
iSQL> --   chained-row layout, which is the code path that crashes.
iSQL> --
iSQL> -- Expected outcome when run standalone: FATAL (server crash, ERR-91015)
iSQL> -- When __TEMP_SORT_ROW_PACKING is 0 (default): runs without error.
iSQL> --
iSQL> -- This test explicitly sets the property to 1 so it can be run in isolation
iSQL> -- without depending on another test leaving dirty state.
iSQL> ALTER SYSTEM SET __TEMP_SORT_ROW_PACKING = 1;
Alter success.
iSQL> CREATE TABLE T_PKD_FATAL
(
    ID   INTEGER,
    GRP  INTEGER,
    V1   VARCHAR(3000),
    V2   VARCHAR(3000)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO T_PKD_FATAL
SELECT LEVEL,
       MOD(LEVEL, 5),
       RPAD('A' || TO_CHAR(LEVEL), 3000, 'A'),
       RPAD('B' || TO_CHAR(MOD(LEVEL, 10)), 3000, 'B')
  FROM DUAL
CONNECT BY LEVEL <= 50;
50 rows inserted.
iSQL> -- This SELECT triggers the crash:
iSQL> --   TEMP_TBS_DISK forces a sort temp table.
iSQL> --   ROW_NUMBER writes back into the sort temp table (packed-row update path).
iSQL> --   With a chained packed row the update crashes the server.
iSQL> SELECT /*+ TEMP_TBS_DISK */
       GRP,
       ID,
       ROW_NUMBER() OVER (PARTITION BY GRP ORDER BY V1, ID) AS RN
  FROM T_PKD_FATAL
 WHERE ROWNUM <= 5
 ORDER BY GRP, RN;
GRP         ID          RN                   
-------------------------------------------------
0           5           1                    
1           11          1                    
1           1           2                    
3           3           1                    
4           9           1                    
5 rows selected.
iSQL> -- Lines below are unreachable if the bug is present (server crashes above).
iSQL> DROP TABLE T_PKD_FATAL;
Drop success.
iSQL> ALTER SYSTEM SET __TEMP_SORT_ROW_PACKING = 0;
Alter success.
