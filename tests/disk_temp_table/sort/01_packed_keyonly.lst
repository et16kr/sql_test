ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify packed-row full scan with ORDER BY can decode key/value columns correctly.
iSQL> -- Checks: Ordered result slice is stable and total row count matches inserted rows.
iSQL> -- Disk sort temp coverage 01: full scan + packed row + key-only compare path
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV01
(
    ID       INTEGER,
    GRP_ID   INTEGER,
    K1       VARCHAR(64),
    K2       VARCHAR(64),
    V1       VARCHAR(3200),
    V2       VARCHAR(3200),
    V3       VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV01
SELECT LEVEL,
       MOD(LEVEL, 37),
       LPAD(TO_CHAR(MOD(LEVEL, 1000)), 8, '0'),
       LPAD(TO_CHAR(MOD(LEVEL, 500)), 8, '0'),
       RPAD('A' || TO_CHAR(LEVEL), 3200, 'A'),
       RPAD('B' || TO_CHAR(MOD(LEVEL, 200)), 3200, 'B'),
       RPAD('C' || TO_CHAR(MOD(LEVEL, 100)), 3200, 'C')
  FROM DUAL
CONNECT BY LEVEL <= 2000;
2000 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK */ ID, GRP_ID
  FROM DST_COV01
 ORDER BY K1, K2, ID
 LIMIT 50;
