ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify LEFT OUTER join with additional conditions keeps outer semantics.
iSQL> -- Checks: Predicate handling does not incorrectly drop required outer rows.
iSQL> -- Disk sort temp coverage HN05: LEFT OUTER with additional join predicate
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV_HN05_A
(
    ID      INTEGER,
    K1      INTEGER,
    PAD1    VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> CREATE TABLE DST_COV_HN05_B
(
    ID      INTEGER,
    K1      INTEGER,
    TAG     CHAR(1),
    PAD1    VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV_HN05_A
SELECT LEVEL,
       MOD(LEVEL, 900),
       RPAD('LA' || TO_CHAR(LEVEL), 3200, 'L')
  FROM DUAL
CONNECT BY LEVEL <= 1300;
1300 rows inserted.
iSQL> INSERT INTO DST_COV_HN05_B
SELECT LEVEL,
       MOD(LEVEL, 900),
       CASE WHEN MOD(LEVEL, 3) = 0 THEN 'Y' ELSE 'N' END,
       RPAD('LB' || TO_CHAR(LEVEL), 3200, 'M')
  FROM DUAL
CONNECT BY LEVEL <= 900;
900 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK USE_SORT(B, A) NO_USE_HASH(B) */
       SUM(CASE WHEN B.K1 IS NULL THEN 1 ELSE 0 END) AS LEFT_ONLY_CNT,
       COUNT(*) AS TOTAL_CNT
  FROM DST_COV_HN05_A A LEFT OUTER JOIN DST_COV_HN05_B B
    ON A.K1 = B.K1
   AND B.TAG = 'Y';
LEFT_ONLY_CNT TOTAL_CNT            
--------------------------------------
867         1300                 
1 row selected.
iSQL> DROP TABLE DST_COV_HN05_A;
Drop success.
iSQL> DROP TABLE DST_COV_HN05_B;
Drop success.
