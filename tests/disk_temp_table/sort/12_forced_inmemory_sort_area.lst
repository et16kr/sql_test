50 rows selected.
iSQL> SELECT CASE WHEN COUNT(*) = 4000 THEN 1 ELSE 0 END AS PASS_COUNT
  FROM DST_COV_FS12;
PASS_COUNT  
--------------
1           
1 row selected.
iSQL> CREATE OR REPLACE PROCEDURE DST_COV_FS12_RESTORE_SORT_AREA
AS
    V_OLD_SORT_AREA BIGINT;
BEGIN
    SELECT OLD_SORT_AREA
      INTO V_OLD_SORT_AREA
      FROM DST_COV_FS12_CFG;

    EXECUTE IMMEDIATE 'ALTER SYSTEM SET SORT_AREA_SIZE = ' || V_OLD_SORT_AREA;
END;
/
Create success.
iSQL> EXECUTE DST_COV_FS12_RESTORE_SORT_AREA;
Execute success.
iSQL> DROP PROCEDURE DST_COV_FS12_RESTORE_SORT_AREA;
Drop success.
iSQL> SELECT CASE
           WHEN VALUE1 = ( SELECT OLD_SORT_AREA FROM DST_COV_FS12_CFG )
           THEN 1 ELSE 0
       END AS PASS_SORT_RESTORE
  FROM V$PROPERTY
 WHERE NAME = 'SORT_AREA_SIZE';
PASS_SORT_RESTORE 
--------------------
1           
1 row selected.
iSQL> DROP TABLE DST_COV_FS12;
Drop success.
iSQL> DROP TABLE DST_COV_FS12_CFG;
Drop success.
