ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Force in-memory sort path using large SORT_AREA_SIZE and verify behavior.
iSQL> -- Checks: Query results are correct and SORT_AREA_SIZE is restored to original value.
iSQL> -- Disk sort temp coverage FS12: force in-memory side with larger SORT_AREA_SIZE
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV_FS12_CFG
(
    OLD_SORT_AREA    BIGINT
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV_FS12_CFG
SELECT VALUE1
  FROM V$PROPERTY
 WHERE NAME = 'SORT_AREA_SIZE';
1 row inserted.
iSQL> ALTER SYSTEM SET SORT_AREA_SIZE = 67108864;
Alter success.
iSQL> CREATE TABLE DST_COV_FS12
(
    ID       INTEGER,
    K1       VARCHAR(128),
    PAD1     VARCHAR(512)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV_FS12
SELECT LEVEL,
       'K' || LPAD(TO_CHAR(MOD(LEVEL, 701)), 4, '0'),
       RPAD('S' || TO_CHAR(MOD(LEVEL, 701)), 300, 'S')
  FROM DUAL
CONNECT BY LEVEL <= 4000;
4000 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK */
       ID,
       K1
  FROM DST_COV_FS12
 ORDER BY K1, ID
 LIMIT 50;
