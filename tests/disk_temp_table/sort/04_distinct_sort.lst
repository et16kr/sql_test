ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify DISTINCT_SORT removes duplicates correctly on disk temp path.
iSQL> -- Checks: Distinct output cardinality and ordered values are as expected.
iSQL> -- Disk sort temp coverage 04: DISTINCT_SORT with wide variable columns
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV04
(
    ID      INTEGER,
    K1      VARCHAR(64),
    K2      VARCHAR(64),
    PAD1    VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV04
SELECT LEVEL,
       'K' || TO_CHAR(MOD(LEVEL, 120)),
       'S' || TO_CHAR(MOD(LEVEL, 45)),
       RPAD('P' || TO_CHAR(MOD(LEVEL, 33)), 3200, 'P')
  FROM DUAL
CONNECT BY LEVEL <= 2400;
2400 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK DISTINCT_SORT */ DISTINCT K1, K2
  FROM DST_COV04
 ORDER BY K1, K2
 LIMIT 60;
