ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Force out-memory sort path using small SORT_AREA_SIZE and verify behavior.
iSQL> -- Checks: Query results are correct and SORT_AREA_SIZE is restored to original value.
iSQL> -- Disk sort temp coverage FS13: force out-memory side with minimal SORT_AREA_SIZE
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_COV_FS13_CFG
(
    OLD_SORT_AREA    BIGINT
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV_FS13_CFG
SELECT VALUE1
  FROM V$PROPERTY
 WHERE NAME = 'SORT_AREA_SIZE';
1 row inserted.
iSQL> ALTER SYSTEM SET SORT_AREA_SIZE = 524288;
Alter success.
iSQL> CREATE TABLE DST_COV_FS13
(
    ID       INTEGER,
    K1       VARCHAR(3200),
    PAD1     VARCHAR(3200),
    PAD2     VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DST_COV_FS13
SELECT LEVEL,
       'K' || LPAD(TO_CHAR(MOD(LEVEL, 10000)), 5, '0')
           || RPAD('X', 2000 + MOD(LEVEL, 10), 'X'),
       RPAD('P' || TO_CHAR(MOD(LEVEL, 4000)), 3200, 'P'),
       RPAD('Q' || TO_CHAR(MOD(LEVEL, 3000)), 3200, 'Q')
  FROM DUAL
CONNECT BY LEVEL <= 40000;
40000 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK */
       ID,
       K1
  FROM DST_COV_FS13
 ORDER BY K1, PAD1, PAD2, ID
 LIMIT 30;
