iSQL> -- If the table already exists, drop it first.
iSQL> create table gb_repro
(
    i_manufact_id  integer,
    i_item_id      char(16),
    i_item_desc    varchar(200),
    i_current_price numeric(7,2)
)
tablespace sys_tbs_disk_data;
