ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Extend the char/varchar hash set-operation regression to legacy hash temp rows with chained row pieces.
iSQL> -- Checks: INTERSECT and MINUS must stay correct when FILTER_ROW compares against multi-piece legacy rows.
iSQL> --         PAD1/PAD2 only widen the temp row, so the logical result must match 05_char_varchar_hash_setop.sql.
iSQL> -- Source: 05_char_varchar_hash_setop.sql
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DST_BUG2_MRP_T1
(
    I1   VARCHAR(3) VARIABLE,
    I2   VARCHAR(3) FIXED,
    PAD1 VARCHAR(12000) FIXED,
    PAD2 VARCHAR(12000) FIXED
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> CREATE TABLE DST_BUG2_MRP_T2
(
    I1   VARCHAR(3) VARIABLE,
    I2   CHAR(3),
    PAD1 CHAR(12000),
    PAD2 CHAR(12000)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> ALTER SYSTEM SET __TEMP_HASH_ROW_PACKING = 0;
Alter success.
iSQL> INSERT INTO DST_BUG2_MRP_T1
VALUES (1, 1, RPAD('T1-01-A', 12000, 'A'), RPAD('T1-01-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T1
VALUES (2, 2, RPAD('T1-02-A', 12000, 'A'), RPAD('T1-02-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T1
VALUES (0, 3, RPAD('T1-03-A', 12000, 'A'), RPAD('T1-03-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T1
VALUES (2, 4, RPAD('T1-04-A', 12000, 'A'), RPAD('T1-04-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T1
VALUES (3, 1, RPAD('T1-05-A', 12000, 'A'), RPAD('T1-05-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T1
VALUES (3, 1, RPAD('T1-05-A', 12000, 'A'), RPAD('T1-05-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T1
VALUES (4, 2, RPAD('T1-06-A', 12000, 'A'), RPAD('T1-06-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T1
VALUES (2, NULL, RPAD('T1-07-A', 12000, 'A'), RPAD('T1-07-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T2
VALUES (1, 1, RPAD('T1-01-A', 12000, 'A'), RPAD('T1-01-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T2
VALUES (2, 2, RPAD('T1-02-A', 12000, 'A'), RPAD('T1-02-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T2
VALUES (1, NULL, RPAD('T1-08-A', 12000, 'A'), RPAD('T1-08-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T2
VALUES (2, 4, RPAD('T1-04-A', 12000, 'A'), RPAD('T1-04-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T2
VALUES (3, 2, RPAD('T1-09-A', 12000, 'A'), RPAD('T1-09-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T2
VALUES (4, 8, RPAD('T1-10-A', 12000, 'A'), RPAD('T1-10-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T2
VALUES (2, 2, RPAD('T1-02-A', 12000, 'A'), RPAD('T1-02-B', 12000, 'B'));
1 row inserted.
iSQL> INSERT INTO DST_BUG2_MRP_T2
VALUES (5, 4, RPAD('T1-11-A', 12000, 'A'), RPAD('T1-11-B', 12000, 'B'));
1 row inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK */ I1, I2
  FROM (
        SELECT I1, I2, PAD1, PAD2 FROM DST_BUG2_MRP_T1
        INTERSECT
        SELECT I1, I2, PAD1, PAD2 FROM DST_BUG2_MRP_T2
       ) X
 ORDER BY I1, I2;
I1   I2   
-------------
No rows selected.
iSQL> SELECT /*+ TEMP_TBS_DISK */ I1, I2
  FROM (
        SELECT I1, I2, PAD1, PAD2 FROM DST_BUG2_MRP_T1
        MINUS
        SELECT I1, I2, PAD1, PAD2 FROM DST_BUG2_MRP_T2
       ) X
 ORDER BY I1, I2;
I1   I2   
-------------
0    3    
1    1    
2    2    
2    4    
2         
3    1    
4    2    
7 rows selected.
iSQL> ALTER SYSTEM SET __TEMP_HASH_ROW_PACKING = 1;
Alter success.
iSQL> DROP TABLE DST_BUG2_MRP_T1;
Drop success.
iSQL> DROP TABLE DST_BUG2_MRP_T2;
Drop success.
