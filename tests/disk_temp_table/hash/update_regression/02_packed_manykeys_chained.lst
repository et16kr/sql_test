iSQL> SELECT CASE WHEN COUNT(*) = 1200 THEN 1 ELSE 0 END AS PASS_MANYKEY_DISTINCT
  FROM (
        SELECT /*+ TEMP_TBS_DISK DISTINCT_HASH */
               DISTINCT K1, K2, K3, K4, K5, K6, K7, K8, K9
          FROM DHASH_COV08
       ) D;
