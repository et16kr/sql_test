20 rows selected.
iSQL> SELECT CASE
           WHEN COUNT(*) = 64 THEN 1 ELSE 0
       END AS PASS_GROUP_SHAPE
  FROM (
        SELECT /*+ TEMP_TBS_DISK GROUP_HASH */
               K1,
               LENGTH(MAX(V_UPD)) AS LEN_MAX_V,
               LENGTH(MAX(PAD1)) AS LEN_MAX_P1,
               LENGTH(MAX(PAD2)) AS LEN_MAX_P2,
               COUNT(*) AS CNT_V
          FROM DHASH_COV16
         GROUP BY K1
       ) G
 WHERE LEN_MAX_V = 9100
   AND LEN_MAX_P1 = 7000
   AND LEN_MAX_P2 = 7000
   AND CNT_V = 10;
PASS_GROUP_SHAPE 
-------------------
1           
1 row selected.
iSQL> SELECT CASE
           WHEN SUM(CNT_V) = 640 THEN 1 ELSE 0
       END AS PASS_ROW_SUM
  FROM (
        SELECT /*+ TEMP_TBS_DISK GROUP_HASH */
               K1,
               COUNT(*) AS CNT_V
          FROM DHASH_COV16
         GROUP BY K1
       ) G;
PASS_ROW_SUM 
---------------
1           
1 row selected.
iSQL> DROP TABLE DHASH_COV16;
Drop success.
