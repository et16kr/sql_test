iSQL> SELECT CASE
           WHEN (
                SELECT COUNT(*)
                  FROM (
                        SELECT /*+ GROUP_HASH */
                               K1
                          FROM DHASH_COV15_MEM_VARUPD
                         GROUP BY K1
                       ) G
                ) = 173
           THEN 1 ELSE 0
       END AS PASS_GROUP_CNT
  FROM DUAL;
PASS_GROUP_CNT 
-----------------
1           
1 row selected.
iSQL> SELECT CASE
           WHEN (
                SELECT SUM(CNT_V)
                  FROM (
                        SELECT /*+ GROUP_HASH */
                               K1,
                               COUNT(*) AS CNT_V
                          FROM DHASH_COV15_MEM_VARUPD
                         GROUP BY K1
                       ) G
                ) = 9000
           THEN 1 ELSE 0
       END AS PASS_ROW_SUM
  FROM DUAL;
PASS_ROW_SUM 
---------------
1           
1 row selected.
iSQL> SELECT CASE
           WHEN (
                SELECT COUNT(*)
                  FROM (
                        SELECT /*+ GROUP_HASH */
                               K1,
                               LENGTH(MIN(V1)) AS LEN_MIN_V1,
                               LENGTH(MAX(V1)) AS LEN_MAX_V1
                          FROM DHASH_COV15_MEM_VARUPD
                         GROUP BY K1
                       ) G
                 WHERE LEN_MIN_V1 = 17
                   AND LEN_MAX_V1 = 3000
                ) = 173
           THEN 1 ELSE 0
       END AS PASS_LEN_BOUNDARY
  FROM DUAL;
PASS_LEN_BOUNDARY 
--------------------
1           
1 row selected.
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 0;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '0' THEN 1 ELSE 0
       END AS PASS_PROP_RESET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_RESET 
------------------
1           
1 row selected.
iSQL> DROP TABLE DHASH_COV15_MEM_VARUPD;
Drop success.
