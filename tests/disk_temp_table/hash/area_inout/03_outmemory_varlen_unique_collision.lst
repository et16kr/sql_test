ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify out-memory hash unique compare handles variable-length key collisions correctly.
iSQL> -- Checks: Prefix-similar but length-different keys are not wrongly merged.
iSQL> -- Disk hash temp packed-row coverage H13: out-memory unique compare with var-length keys
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DHASH_COV13_CFG
(
    OLD_HASH_AREA    BIGINT
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DHASH_COV13_CFG
SELECT VALUE1
  FROM V$PROPERTY
 WHERE NAME = 'HASH_AREA_SIZE';
1 row inserted.
iSQL> ALTER SYSTEM SET HASH_AREA_SIZE = 3145728;
Alter success.
iSQL> CREATE TABLE DHASH_COV13_VAR
(
    ID       INTEGER,
    K1       VARCHAR(3200),
    PAD1     VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> CREATE TABLE DHASH_COV13_MET
(
    BASE_USED_TEMP_PAGE    BIGINT
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DHASH_COV13_VAR
SELECT LEVEL,
       'PX' || LPAD(TO_CHAR(MOD(LEVEL, 1000)), 4, '0')
             || RPAD('A',
                     2200 + MOD(TRUNC((LEVEL - 1) / 1000), 5),
                     'A'),
       RPAD('W' || TO_CHAR(MOD(LEVEL, 5000)), 3200, 'W')
  FROM DUAL
CONNECT BY LEVEL <= 60000;
60000 rows inserted.
iSQL> INSERT INTO DHASH_COV13_MET
SELECT VALUE
  FROM X$TEMPINFO
 WHERE NAME = 'TOTAL USED TEMP PAGE COUNT';
1 row inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK DISTINCT_HASH */
       COUNT(*) AS DISTINCT_CNT
  FROM (
        SELECT DISTINCT K1
          FROM DHASH_COV13_VAR
       ) D;
DISTINCT_CNT         
-----------------------
5000                 
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 5000 THEN 1 ELSE 0 END AS PASS_DISTINCT
  FROM (
        SELECT /*+ TEMP_TBS_DISK DISTINCT_HASH */ DISTINCT K1
          FROM DHASH_COV13_VAR
       ) D;
PASS_DISTINCT 
----------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 5 THEN 1 ELSE 0 END AS PASS_LEN_VARIANTS
  FROM (
        SELECT DISTINCT LENGTH(K1) AS L1
          FROM (
                SELECT /*+ TEMP_TBS_DISK DISTINCT_HASH */ DISTINCT K1
                  FROM DHASH_COV13_VAR
               ) D
       ) L;
PASS_LEN_VARIANTS 
--------------------
1           
1 row selected.
iSQL> SELECT CASE
           WHEN (
                ( SELECT VALUE
                    FROM X$TEMPINFO
                   WHERE NAME = 'TOTAL USED TEMP PAGE COUNT' )
                - ( SELECT BASE_USED_TEMP_PAGE
                      FROM DHASH_COV13_MET )
                ) > 256
           THEN 1 ELSE 0
       END AS PASS_OUTMEM_USED_TEMP
  FROM DUAL;
PASS_OUTMEM_USED_TEMP 
------------------------
1           
1 row selected.
iSQL> CREATE OR REPLACE PROCEDURE DHASH_COV13_RESTORE_HASH_AREA
AS
    V_OLD_HASH_AREA BIGINT;
BEGIN
    SELECT OLD_HASH_AREA
      INTO V_OLD_HASH_AREA
      FROM DHASH_COV13_CFG;

    EXECUTE IMMEDIATE 'ALTER SYSTEM SET HASH_AREA_SIZE = ' || V_OLD_HASH_AREA;
END;
/
Create success.
iSQL> EXECUTE DHASH_COV13_RESTORE_HASH_AREA;
Execute success.
iSQL> DROP PROCEDURE DHASH_COV13_RESTORE_HASH_AREA;
Drop success.
iSQL> SELECT CASE
           WHEN VALUE1 = ( SELECT OLD_HASH_AREA FROM DHASH_COV13_CFG )
           THEN 1 ELSE 0
       END AS PASS_HASH_RESTORE
  FROM V$PROPERTY
 WHERE NAME = 'HASH_AREA_SIZE';
PASS_HASH_RESTORE 
--------------------
1           
1 row selected.
iSQL> DROP TABLE DHASH_COV13_MET;
Drop success.
iSQL> DROP TABLE DHASH_COV13_VAR;
Drop success.
iSQL> DROP TABLE DHASH_COV13_CFG;
Drop success.
