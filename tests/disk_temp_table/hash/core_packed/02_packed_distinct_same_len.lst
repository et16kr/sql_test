30 rows selected.
iSQL> SELECT CASE WHEN COUNT(*) = 200 THEN 1 ELSE 0 END AS PASS_DISTINCT_CNT
  FROM (
        SELECT /*+ TEMP_TBS_DISK DISTINCT_HASH */ DISTINCT K1
          FROM DHASH_COV02
       ) D;
PASS_DISTINCT_CNT 
--------------------
1           
1 row selected.
iSQL> DROP TABLE DHASH_COV02;
Drop success.
