ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify DISTINCT_HASH duplicate handling when variable-length keys share same length.
iSQL> -- Checks: Duplicate keys with same physical length are deduplicated correctly.
iSQL> -- Disk hash temp packed-row coverage H02: distinct(unique) with same-length duplicates
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/iSQL User's Manual.md
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> CREATE TABLE DHASH_COV02
(
    ID       INTEGER,
    K1       VARCHAR(120),
    PAD1     VARCHAR(3200)
) TABLESPACE SYS_TBS_DISK_DATA;
Create success.
iSQL> INSERT INTO DHASH_COV02
SELECT LEVEL,
       'KEY_' || LPAD(TO_CHAR(MOD(LEVEL, 200)), 3, '0'),
       RPAD('P' || TO_CHAR(LEVEL), 3200, 'P')
  FROM DUAL
CONNECT BY LEVEL <= 3000;
3000 rows inserted.
iSQL> SELECT /*+ TEMP_TBS_DISK DISTINCT_HASH */
       COUNT(*) AS DISTINCT_CNT
  FROM (
        SELECT DISTINCT K1
          FROM DHASH_COV02
       ) D;
DISTINCT_CNT         
-----------------------
200                  
1 row selected.
iSQL> SELECT /*+ TEMP_TBS_DISK DISTINCT_HASH */
       K1
  FROM (
        SELECT DISTINCT K1
          FROM DHASH_COV02
       ) D
 ORDER BY K1
 LIMIT 30;
