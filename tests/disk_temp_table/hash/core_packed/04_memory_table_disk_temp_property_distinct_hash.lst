30 rows selected.
iSQL> SELECT CASE
           WHEN (
                SELECT /*+ DISTINCT_HASH */ COUNT(*)
                  FROM (
                        SELECT DISTINCT K1
                          FROM DHASH_COV04_MEM
                       ) X
                ) = 211
           THEN 1 ELSE 0
       END AS PASS_DISTINCT_CNT
  FROM DUAL;
PASS_DISTINCT_CNT 
--------------------
1           
1 row selected.
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 0;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '0' THEN 1 ELSE 0
       END AS PASS_PROP_RESET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_RESET 
------------------
1           
1 row selected.
iSQL> DROP TABLE DHASH_COV04_MEM;
Drop success.
