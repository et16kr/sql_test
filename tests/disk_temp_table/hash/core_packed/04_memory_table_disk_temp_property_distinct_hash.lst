ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Validate DISTINCT_HASH on memory table with disk-temp default property.
iSQL> -- Checks:
iSQL> --   1) table is created without TABLESPACE clause (memory table path)
iSQL> --   2) __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 2 is applied
iSQL> --   3) DISTINCT_HASH results are correct
iSQL> --   4) property is reset to default (0) at end
iSQL> -- Manual reference:
iSQL> --   docs/manuals/altibase/Altibase_7.1/eng/Performance Tuning Guide.md
iSQL> ALTER SYSTEM SET __OPTIMIZER_DEFAULT_TEMP_TBS_TYPE = 2;
Alter success.
iSQL> SELECT CASE
           WHEN MEMORY_VALUE1 = '2' THEN 1 ELSE 0
       END AS PASS_PROP_SET
  FROM X$PROPERTY
 WHERE NAME = '__OPTIMIZER_DEFAULT_TEMP_TBS_TYPE';
PASS_PROP_SET 
----------------
1           
1 row selected.
iSQL> CREATE TABLE DHASH_COV04_MEM
(
    ID      INTEGER,
    K1      VARCHAR(256),
    V1      VARCHAR(512)
);
Create success.
iSQL> INSERT INTO DHASH_COV04_MEM
SELECT LEVEL,
       'K' || LPAD(TO_CHAR(MOD(LEVEL, 211)), 4, '0'),
       RPAD('V' || TO_CHAR(MOD(LEVEL, 211)), 300, 'V')
  FROM DUAL
CONNECT BY LEVEL <= 5000;
5000 rows inserted.
iSQL> SELECT /*+ DISTINCT_HASH */
       COUNT(*) AS DISTINCT_CNT
  FROM (
        SELECT DISTINCT K1
          FROM DHASH_COV04_MEM
       ) D;
DISTINCT_CNT         
-----------------------
211                  
1 row selected.
iSQL> SELECT /*+ DISTINCT_HASH */
       K1
  FROM (
        SELECT DISTINCT K1
          FROM DHASH_COV04_MEM
       ) D
 ORDER BY K1
 LIMIT 30;
