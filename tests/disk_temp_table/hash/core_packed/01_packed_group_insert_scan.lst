40 rows selected.
iSQL> SELECT CASE WHEN SUM(CNT) = 2600 THEN 1 ELSE 0 END AS PASS_SUM
  FROM (
        SELECT /*+ TEMP_TBS_DISK GROUP_HASH */
               COUNT(*) AS CNT
          FROM DHASH_COV01
         GROUP BY K1
       ) X;
PASS_SUM    
--------------
1           
1 row selected.
iSQL> DROP TABLE DHASH_COV01;
Drop success.
