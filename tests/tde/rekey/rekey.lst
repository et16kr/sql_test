ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Rekey an existing encrypted MRDB tablespace to the active master key.
iSQL> -- Checks: The encrypted tablespace now points to the active key and the operation view reports success.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 2 THEN 1 ELSE 0 END AS PASS_ENC_COUNT FROM TDE2_ENC_T;
PASS_ENC_COUNT 
----------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_REKEYED_TBS
  FROM V$TDE_TABLESPACES
 WHERE NAME = 'TDE2_ENC_TBS'
   AND IS_ENCRYPTED = 1
   AND MASTER_KEY_ID = (SELECT KEY_ID FROM V$TDE_MASTER_KEYS WHERE IS_ACTIVE = 1);
PASS_REKEYED_TBS 
------------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_OPERATION
  FROM V$TDE_OPERATION
 WHERE OPERATION = 'REKEY'
   AND STATE = 'SUCCESS';
PASS_OPERATION 
----------------
1           
1 row selected.
