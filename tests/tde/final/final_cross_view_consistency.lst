ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Cross-check the final all-plain state after every decrypt path has completed.
iSQL> -- Checks: All tracked MRDB tablespaces are plain and no master key keeps a referenced tablespace count.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 6 THEN 1 ELSE 0 END AS PASS_ALL_PLAIN FROM V$TABLESPACES WHERE NAME IN ('TDE_SQLT_TBS', 'TDE2_PLAIN_TBS', 'TDE2_ENC_TBS', 'TDE_TMP_PLAIN_TBS', 'TDE_TMP_NEW_ENC_TBS', 'TDE_TMP_EMPTY_PLAIN_TBS') AND IS_ENCRYPTED = 0 AND MASTER_KEY_ID = 0;
PASS_ALL_PLAIN
---------------
1
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 6 THEN 1 ELSE 0 END AS PASS_ALL_PLAIN_TDE FROM V$TDE_TABLESPACES WHERE NAME IN ('TDE_SQLT_TBS', 'TDE2_PLAIN_TBS', 'TDE2_ENC_TBS', 'TDE_TMP_PLAIN_TBS', 'TDE_TMP_NEW_ENC_TBS', 'TDE_TMP_EMPTY_PLAIN_TBS') AND IS_ENCRYPTED = 0 AND MASTER_KEY_ID = 0;
PASS_ALL_PLAIN_TDE
-------------------
1
1 row selected.
iSQL> SELECT CASE WHEN (SELECT SUM(REFERENCED_TABLESPACE_COUNT) FROM V$TDE_MASTER_KEYS) = 0 THEN 1 ELSE 0 END AS PASS_ZERO_REFCOUNT FROM DUAL;
PASS_ZERO_REFCOUNT
-------------------
1
1 row selected.
