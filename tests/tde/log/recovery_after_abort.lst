ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 20101
iSQL> -- Test Purpose: Verify startup redo recovery can replay encrypted memory log payloads after shutdown abort.
iSQL> -- Checks: The committed row survives recovery and its payload marker is absent from log files.
iSQL> -- Manual reference:
iSQL> --   /home/et16/work/altidev4/docs/manuals/altibase/trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_RECOVERED_ROW
  FROM TDE_SQLT_T
 WHERE I = 1103
   AND V = 'TDE11_RECOVERY_MARKER';
PASS_RECOVERED_ROW 
---------------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_ENCRYPTED_TBS
  FROM V$TDE_TABLESPACES
 WHERE NAME = 'TDE_SQLT_TBS'
   AND IS_ENCRYPTED = 1
   AND MASTER_KEY_ID > 0;
PASS_ENCRYPTED_TBS 
---------------------
1           
1 row selected.
