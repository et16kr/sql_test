ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Recheck the base encrypted table rows and values.
iSQL> -- Checks: The bootstrap fixture still contains the expected MRDB data.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 2 THEN 1 ELSE 0 END AS PASS_BASE_ROWS FROM TDE_SQLT_T;
PASS_BASE_ROWS
----------------
1
1 row selected.
iSQL> SELECT CASE WHEN MIN(I) = 1 AND MAX(I) = 2 THEN 1 ELSE 0 END AS PASS_BASE_RANGE FROM TDE_SQLT_T;
PASS_BASE_RANGE
-----------------
1
1 row selected.
iSQL> SELECT CASE WHEN SUM(CASE WHEN V IN ('alpha', 'beta') THEN 1 ELSE 0 END) = 2 THEN 1 ELSE 0 END AS PASS_BASE_VALUES FROM TDE_SQLT_T;
PASS_BASE_VALUES
------------------
1
1 row selected.
