ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Check referenced tablespace counts after creating a new encrypted tablespace under the latest key.
iSQL> -- Checks: Active-key and total-key reference counts match the visible tablespace state.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN (SELECT REFERENCED_TABLESPACE_COUNT FROM V$TDE_MASTER_KEYS WHERE IS_ACTIVE = 1) = 1 THEN 1 ELSE 0 END AS PASS_ACTIVE_REFCOUNT FROM DUAL;
PASS_ACTIVE_REFCOUNT
---------------------
1
1 row selected.
iSQL> SELECT CASE WHEN (SELECT SUM(REFERENCED_TABLESPACE_COUNT) FROM V$TDE_MASTER_KEYS) = 3 THEN 1 ELSE 0 END AS PASS_TOTAL_REFCOUNT FROM DUAL;
PASS_TOTAL_REFCOUNT
--------------------
1
1 row selected.
