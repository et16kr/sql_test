ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Rotate the master key without rekeying existing tablespaces.
iSQL> -- Checks: Active key changes and the existing encrypted tablespace still points to the old key.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) >= 2 THEN 1 ELSE 0 END AS PASS_KEY_COUNT FROM V$TDE_MASTER_KEYS;
PASS_KEY_COUNT 
----------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_ACTIVE_COUNT FROM V$TDE_MASTER_KEYS WHERE IS_ACTIVE = 1;
PASS_ACTIVE_COUNT 
-------------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_OLD_KEY_RETAINED
  FROM V$TABLESPACES
 WHERE NAME = 'TDE2_ENC_TBS'
   AND MASTER_KEY_ID <> (SELECT KEY_ID FROM V$TDE_MASTER_KEYS WHERE IS_ACTIVE = 1);
PASS_OLD_KEY_RETAINED 
-----------------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 2 THEN 1 ELSE 0 END AS PASS_ENC_COUNT FROM TDE2_ENC_T;
PASS_ENC_COUNT 
----------------
1           
1 row selected.
