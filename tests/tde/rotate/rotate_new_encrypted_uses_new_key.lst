ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Create a new encrypted tablespace after the second rotate.
iSQL> -- Checks: The new encrypted tablespace uses the current active master key.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_NEW_ROWS FROM TDE_TMP_NEW_ENC_T;
PASS_NEW_ROWS
--------------
1
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_NEW_KEY FROM V$TABLESPACES WHERE NAME = 'TDE_TMP_NEW_ENC_TBS' AND MASTER_KEY_ID = (SELECT KEY_ID FROM V$TDE_MASTER_KEYS WHERE IS_ACTIVE = 1);
PASS_NEW_KEY
-------------
1
1 row selected.
