ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Rotate the master key a second time.
iSQL> -- Checks: Key history grows while only one key remains active.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 3 THEN 1 ELSE 0 END AS PASS_KEY_COUNT FROM V$TDE_MASTER_KEYS;
PASS_KEY_COUNT
---------------
1
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_ACTIVE_COUNT FROM V$TDE_MASTER_KEYS WHERE IS_ACTIVE = 1;
PASS_ACTIVE_COUNT
------------------
1
1 row selected.
