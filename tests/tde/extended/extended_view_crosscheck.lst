ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Cross-check general and dedicated views for the extended MRDB fixtures.
iSQL> -- Checks: Plain and encrypted extended tablespaces are visible with the expected state.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_EXT_PLAIN FROM V$TABLESPACES WHERE NAME = 'TDE2_PLAIN_TBS' AND IS_ENCRYPTED = 0;
PASS_EXT_PLAIN
---------------
1
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_EXT_ENC FROM V$TDE_TABLESPACES WHERE NAME = 'TDE2_ENC_TBS' AND IS_ENCRYPTED = 1 AND ENCRYPT_ALGORITHM = 'AES-256-CTR';
PASS_EXT_ENC
-------------
1
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_REFCOUNT FROM V$TDE_MASTER_KEYS WHERE IS_ACTIVE = 1 AND REFERENCED_TABLESPACE_COUNT = 2;
PASS_REFCOUNT
--------------
1
1 row selected.
