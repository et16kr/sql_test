ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Prepare additional MRDB TDE objects for rotate and offline convert coverage.
iSQL> -- Checks: Plain and encrypted MRDB tablespaces are created and visible.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 2 THEN 1 ELSE 0 END AS PASS_PLAIN_COUNT FROM TDE2_PLAIN_T;
PASS_PLAIN_COUNT 
------------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 2 THEN 1 ELSE 0 END AS PASS_ENC_COUNT FROM TDE2_ENC_T;
PASS_ENC_COUNT 
----------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_PLAIN_TBS FROM V$TABLESPACES WHERE NAME = 'TDE2_PLAIN_TBS' AND IS_ENCRYPTED = 0;
PASS_PLAIN_TBS 
----------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_ENC_TBS FROM V$TABLESPACES WHERE NAME = 'TDE2_ENC_TBS' AND IS_ENCRYPTED = 1 AND ENCRYPT_ALGORITHM = 'AES-256-CTR' AND MASTER_KEY_ID > 0;
PASS_ENC_TBS 
--------------
1           
1 row selected.
