ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 20101
iSQL> -- Test Purpose: Verify v3 TDE files keep readable header metadata while encrypting page body data.
iSQL> -- Checks: The helper validates header magic and plaintext absence, then SQL checks row visibility.
iSQL> -- Manual reference:
iSQL> --   /home/et16/work/altidev4/docs/manuals/altibase/trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_MARKER_ROW
  FROM TDE_SQLT_T
 WHERE I = 902
   AND V = 'TDE9_SECRET_BODY';
PASS_MARKER_ROW 
------------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_ENCRYPTED_TBS
  FROM V$TDE_TABLESPACES
 WHERE NAME = 'TDE_SQLT_TBS'
   AND IS_ENCRYPTED = 1
   AND MASTER_KEY_ID > 0;
PASS_ENCRYPTED_TBS 
---------------------
1           
1 row selected.
