ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 20101
iSQL> -- Test Purpose: Verify offline decrypt/re-encrypt of the same logical rows produces fresh ciphertext.
iSQL> -- Checks: The helper compares copied encrypted files and their nonces across offline conversions.
iSQL> -- Manual reference:
iSQL> --   /home/et16/work/altidev4/docs/manuals/altibase/trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_MARKER_ROW
  FROM TDE_TMP_PLAIN_T
 WHERE I = 904
   AND V = 'TDE9_OFFLINE_NONCE';
PASS_MARKER_ROW 
------------------
1           
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_ENCRYPTED_TBS
  FROM V$TDE_TABLESPACES
 WHERE NAME = 'TDE_TMP_PLAIN_TBS'
   AND IS_ENCRYPTED = 1
   AND MASTER_KEY_ID > 0;
PASS_ENCRYPTED_TBS 
---------------------
1           
1 row selected.
