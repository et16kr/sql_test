ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Start the server with TDE_AUTO_LOAD=0 and no keystore while every MRDB TDE tablespace is plain.
iSQL> -- Checks: Plain tablespaces stay readable after the helper restores the normal environment.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 6 THEN 1 ELSE 0 END AS PASS_PLAIN_TBS FROM V$TDE_TABLESPACES WHERE NAME IN ('TDE_SQLT_TBS', 'TDE2_PLAIN_TBS', 'TDE2_ENC_TBS', 'TDE_TMP_PLAIN_TBS', 'TDE_TMP_NEW_ENC_TBS', 'TDE_TMP_EMPTY_PLAIN_TBS') AND IS_ENCRYPTED = 0 AND MASTER_KEY_ID = 0;
PASS_PLAIN_TBS
----------------
1
1 row selected.
iSQL> SELECT CASE WHEN (SELECT COUNT(*) FROM TDE_SQLT_T) = 2 AND (SELECT COUNT(*) FROM TDE2_ENC_T) = 2 AND (SELECT COUNT(*) FROM TDE_TMP_NEW_ENC_T) = 1 THEN 1 ELSE 0 END AS PASS_ROWS FROM DUAL;
PASS_ROWS
-----------
1
1 row selected.
