1 row selected.
iSQL> SELECT CASE WHEN SUM(CASE WHEN (I = 1 AND V = 'alpha') OR (I = 2 AND V = 'beta') THEN 1 ELSE 0 END) = 2 THEN 1 ELSE 0 END AS PASS_DISTINCT FROM TDE_SQLT_T;
