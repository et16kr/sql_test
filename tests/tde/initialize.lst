ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 20101
iSQL> -- Test Purpose: Reset the dedicated TDE test environment and rebuild the base fixture.
iSQL> -- Checks: Common keystore, master-key, and base encrypted tablespace setup completes and leaves visible base fixture metadata.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 2 THEN 1 ELSE 0 END AS PASS_COUNT FROM TDE_SQLT_T;
