ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Restore an older checkpoint-image snapshot with the current key history still present.
iSQL> -- Checks: The older snapshot starts successfully and the latest active key remains unreferenced.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN (SELECT COUNT(*) FROM TDE_SQLT_T) = 2 AND (SELECT COUNT(*) FROM TDE2_ENC_T) = 2 AND (SELECT COUNT(*) FROM TDE_TMP_NEW_ENC_T) = 1 THEN 1 ELSE 0 END AS PASS_ROWS FROM DUAL;
PASS_ROWS
-----------
1
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_ZERO_ACTIVE_REFCOUNT FROM V$TDE_MASTER_KEYS WHERE IS_ACTIVE = 1 AND REFERENCED_TABLESPACE_COUNT = 0;
PASS_ZERO_ACTIVE_REFCOUNT
--------------------------
1
1 row selected.
