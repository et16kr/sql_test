ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Create a plain MRDB tablespace while TDE is enabled.
iSQL> -- Checks: Plain tablespace metadata and row values are normal.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 2 THEN 1 ELSE 0 END AS PASS_PLAIN_ROWS FROM TDE_TMP_PLAIN_T;
PASS_PLAIN_ROWS
-----------------
1
1 row selected.
iSQL> SELECT CASE WHEN SUM(CASE WHEN V IN ('plain-one', 'plain-two') THEN 1 ELSE 0 END) = 2 THEN 1 ELSE 0 END AS PASS_PLAIN_VALUES FROM TDE_TMP_PLAIN_T;
PASS_PLAIN_VALUES
-------------------
1
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_PLAIN_TBS FROM V$TABLESPACES WHERE NAME = 'TDE_TMP_PLAIN_TBS' AND IS_ENCRYPTED = 0;
PASS_PLAIN_TBS
----------------
1
1 row selected.
