ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Verify plain and encrypted MRDB fixtures remain usable together.
iSQL> -- Checks: Both tables are readable and each tablespace keeps the expected encryption state.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN (SELECT COUNT(*) FROM TDE_SQLT_T) = 2 AND (SELECT COUNT(*) FROM TDE_TMP_PLAIN_T) = 2 THEN 1 ELSE 0 END AS PASS_MIXED_ROWS FROM DUAL;
PASS_MIXED_ROWS
-----------------
1
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_ENC_STATE FROM V$TABLESPACES WHERE NAME = 'TDE_SQLT_TBS' AND IS_ENCRYPTED = 1;
PASS_ENC_STATE
----------------
1
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_PLAIN_STATE FROM V$TABLESPACES WHERE NAME = 'TDE_TMP_PLAIN_TBS' AND IS_ENCRYPTED = 0;
PASS_PLAIN_STATE
------------------
1
1 row selected.
