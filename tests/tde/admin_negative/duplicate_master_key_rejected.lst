ISQL_CONNECTION = TCP, SERVER = localhost, PORT_NO = 17730
iSQL> -- Test Purpose: Re-run CREATE MASTER KEY after bootstrap.
iSQL> -- Checks: The server is recovered and the base encrypted tablespace remains readable.
iSQL> -- Manual reference:
iSQL> --   doc/altibase-docs/Manuals/Altibase_trunk/eng/iSQL User's Manual.md
iSQL> SELECT CASE WHEN COUNT(*) = 2 THEN 1 ELSE 0 END AS PASS_BASE_ROWS FROM TDE_SQLT_T;
PASS_BASE_ROWS
----------------
1
1 row selected.
iSQL> SELECT CASE WHEN COUNT(*) = 1 THEN 1 ELSE 0 END AS PASS_BASE_KEY FROM V$TDE_MASTER_KEYS WHERE IS_ACTIVE = 1;
PASS_BASE_KEY
---------------
1
1 row selected.
